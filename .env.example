# Copy to .env and fill in. (.env is gitignored.)
# A billing-enabled Google Cloud project id. Querying patents-public-data stays within the
# 1 TB/month BigQuery free tier; billing just needs to be enabled on the project.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional: lower the cost guard while testing (bytes). Default ~1.1 TB.
# WIPO_MAX_BYTES_BILLED=200000000000
